// Compiler pipeline — source to executable (modelled on LLVM/GCC architecture)

SourceFile { path: s@, language: (c|cpp|rust|go|swift|zig), size_bytes: i(0,), hash: s!^, encoding: s="utf-8", parsed_at: dt? }
Token { source: SourceFile, type: (keyword|identifier|literal|operator|punctuation|comment|whitespace), lexeme: s, line: i(1,), col: i(1,), span: i(1,) }
ASTNode { source: SourceFile, type: s, parent: ASTNode?, depth: i(0,), start_line: i(1,), end_line: i(1,), symbol_name: s?, exported: b=false }
Symbol { node: ASTNode, name: s~, kind: (function|variable|type|constant|macro|module), scope: s, type_signature: s?, visibility: (public|private|internal)=private }
IRInstruction { block: BasicBlock, opcode: s, operands: [s], result_type: s?, position: i++ }
BasicBlock { function: Symbol, label: s@, predecessors: [BasicBlock], successors: [BasicBlock] }
Diagnostic { source: SourceFile, severity: (error|warning|note|hint), code: s?, message: t, line: i(1,), col: i(1,), fix_suggestion: t? }
